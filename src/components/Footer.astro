---
import services from "../data/services.json";
import areas from "../data/areas.json";
const year = new Date().getFullYear();
const footerServices = (services as {name:string}[]).slice(0,6);
const footerAreas = (areas as {city:string}[]).slice(0,13);
---

<footer class="border-t border-ps-muted bg-white">
  <div class="max-w-6xl mx-auto px-4 lg:px-6 py-8 grid gap-8 md:grid-cols-4 text-xs text-ps-navy/80">
    <div>
      <h2 class="text-sm font-semibold text-ps-navy">Postal Systems</h2>
      <p class="mt-2">
        USPS-approved commercial mailbox installation, repair, and replacements for HOAs, apartments, builders, and facilities.
      </p>
      <p class="mt-3">
        Licensed, bonded & insured in California. CA Lic. #904106.
      </p>
    </div>

    <div>
      <h3 class="text-[11px] font-semibold tracking-[0.16em] uppercase text-ps-navy">Services</h3>
      <ul class="mt-2 space-y-1">
        {footerServices.map((service) => (<li><a href={`/services/${service.name.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/(^-|-$)/g, "")}/`} class="hover:text-ps-navy">{service.name}</a></li>))}
      </ul>
    </div>

    <div>
      <h3 class="text-[11px] font-semibold tracking-[0.16em] uppercase text-ps-navy">Service areas</h3>
      <ul class="mt-2 space-y-1">
        {footerAreas.map((area) => (<li><a href={`/service-areas/${area.city.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/(^-|-$)/g, "")}/`} class="hover:text-ps-navy">{area.city}, CA</a></li>))}
      </ul>
    </div>

    <div>
      <h3 class="text-[11px] font-semibold tracking-[0.16em] uppercase text-ps-navy">Contact</h3>
      <p class="mt-2">
        Phone: <a href="tel:16194614787" data-ga-event="click_to_call" data-ga-category="Contact" data-ga-label="main_phone" class="font-semibold hover:text-ps-navy">(619) 461-4787</a>
      </p>
      <p class="mt-1">
        Email: <a href="mailto:info@postalsystemspro.com" class="font-semibold hover:text-ps-navy">info@postalsystemspro.com</a>
      </p>
      <p class="mt-3">
        Based in San Diego County, serving nearby cities plus select projects in Temecula, Riverside County, and Orange County.
      </p>
      <p class="mt-3">
        <a
          href="/contact/"
          class="inline-flex items-center justify-center rounded-full bg-ps-navy px-4 py-1.5 text-[12px] font-semibold text-white shadow-md hover:bg-ps-navy/90 transition"
        >
          Request a quote
        </a>
      </p>
    </div>
  </div>

  <div class="border-t border-ps-muted bg-ps-surface">
    <div class="max-w-6xl mx-auto px-4 lg:px-6 py-3 flex flex-col sm:flex-row items-center justify-between gap-2 text-[11px] text-ps-navy/70">
      <span>© {year} Postal Systems. All rights reserved.</span>
      <span class="text-center">
        Website designed by
        <a
          href="https://lilosgrowth.com"
          target="_blank"
          rel="noopener noreferrer"
          class="font-semibold hover:text-ps-navy"
        >
          Lilos Growth
        </a>.
      </span>
      <span class="sm:text-right">
        USPS-approved contractor for commercial mailbox systems.
      </span>
    </div>
  </div>
</footer>
